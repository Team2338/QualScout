# Environment Variables
# Copy this file to .env.local and fill in your values

# API Configuration
VITE_API_BASE_URL=https://api.gearitforward.com

# App Version (automatically set during build)
VITE_APP_VERSION=2026.0.3

# Feature Flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_ERROR_TRACKING=false
